---
interface Props {
  href: string;
  buttonText?: string;
  noteText: string;
}

const { href, buttonText = 'Message us on WhatsApp', noteText } = Astro.props;
---

<div class="wa-cta-wrap">
  <a href={href} class="wa-btn" target="_blank" rel="noopener noreferrer">
    <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
      <circle cx="11" cy="11" r="11" fill="#fff" fill-opacity="0.18" />
      <path d="M11 5.1a5.9 5.9 0 00-5 9.1l-.7 2.6 2.7-.7A5.9 5.9 0 1011 5.1zm0 10.6c-.9 0-1.7-.2-2.5-.7l-.2-.1-1.6.4.4-1.6-.1-.2A4.6 4.6 0 1111 15.7zm2.5-3.4c-.1-.1-.8-.4-1-.4-.1-.1-.2-.1-.3.1l-.4.5c-.1.1-.2.1-.3.1-.5-.2-1.5-.9-2-1.8-.1-.1 0-.2.1-.3l.3-.4c.1-.1.1-.2.1-.3 0-.1-.3-.8-.4-1-.1-.2-.2-.2-.3-.2h-.2c-.1 0-.3 0-.4.2-.1.2-.4.5-.4 1.1 0 .6.4 1.2.5 1.3.1.1.9 1.5 2.3 2.1 1.3.5 1.3.3 1.6.3.3 0 .8-.3.9-.6.1-.3.1-.6 0-.6z" fill="#fff" />
    </svg>
    {buttonText}
  </a>
  <div class="online-indicator"><span class="wa-pulse"></span>Usually replies within the hour</div>
  <p class="form-note">{noteText}</p>
</div>
